{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Bash(npm run typecheck)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm run build:*)",
      "Bash(npm --workspace*)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npx tsc*)",
      "Bash(npx jest*)",
      "Bash(npx expo export*)",
      "Bash(npx supabase db*)",
      "Bash(npx supabase migration*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "env": {
    "TZ": "Africa/Cairo"
  }
}
