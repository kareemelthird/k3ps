# ──────────────────────────────────────────────────────────────────────────────
# PS-Managment — environment variables template
# Copy to .env.local (web) or .env (root/local) and fill in your values.
# NEVER commit this file with real secrets. The repo is PUBLIC.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (publishable — safe to embed in client bundles) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>

# ── Sentry observability (ADR-0011) ───────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN is publishable (client-safe by design).
# Leave blank in dev/CI to keep Sentry fully disabled (zero overhead).
NEXT_PUBLIC_SENTRY_DSN=

# SENTRY_AUTH_TOKEN is SERVER / CI-only — never commit, never embed in any
# client bundle. Used only for source-map upload during production builds.
# When absent, source-map upload is silently skipped; the build still succeeds.
SENTRY_AUTH_TOKEN=

# Optional: Sentry organisation slug and project name for withSentryConfig.
SENTRY_ORG=
SENTRY_PROJECT=

# ── Stripe (server-only — NEVER put these in NEXT_PUBLIC_*) ──────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key for the client checkout flow (safe in NEXT_PUBLIC)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Expo / mobile (publishable — safe in EXPO_PUBLIC_*) ──────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>
# Leave blank in dev; fill per EAS profile for preview/production.
EXPO_PUBLIC_SENTRY_DSN=
