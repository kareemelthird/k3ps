{
  "expo": {
    "name": "PS-Managment",
    "slug": "ps-managment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ps-managment",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C13"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ps.managment"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#080C13"
      },
      "package": "com.ps.managment"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080C13"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "<sentry-org-slug>",
          "project": "<sentry-project-slug>"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
